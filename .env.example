# Production runtime
NODE_ENV=production
PORT=3001
BASE_PATH=/

# PostgreSQL database used by the real API and session store.
# Do not use scripts/mock-api.mjs in production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Required by express-session. Use a long random value and keep it secret.
SESSION_SECRET=replace-with-a-long-random-secret

# Optional logging
LOG_LEVEL=info

# Optional email support for password reset / welcome / OTP emails.
# Leave empty if email sending is not configured yet.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional Telegram notifications.
# Create a Telegram bot with BotFather and put the token here.
TELEGRAM_BOT_TOKEN=

# Optional but recommended for secure Telegram linking webhook.
# Webhook URL format:
# https://YOUR_DOMAIN/api/telegram/webhook/YOUR_SECRET
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
